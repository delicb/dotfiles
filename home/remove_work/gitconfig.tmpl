{{/*- if (and .work (not .ephemeral)) -*/}}  # TODO: only work profile later
[user]
    signingkey = {{ onepasswordRead "op://Private/MainSSHKey/public key" }}

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true
{{/* end */}}
