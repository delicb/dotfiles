import type {
    BrowserHandler,
    BrowserResolver,
    BrowserSpecification,
    FinickyConfig,
    ProcessInfo,
    UrlMatcher,
    UrlMatcherFunction,
    UrlTransformer,
} from "/Applications/Finicky.app/Contents/Resources/finicky.d.ts";

const SLACK_BUNDLE_ID = "com.tinyspeck.slackmacgap";
const NOTION_BUNDLE_ID = "notion.id";

function matchesSourceApp(opener: ProcessInfo | null, sourceAppBundleIds: string[]): boolean {
    return sourceAppBundleIds.length === 0 || Boolean(opener && sourceAppBundleIds.includes(opener.bundleId));
}

function hostMatchesDomain(hostname: string, domain: string): boolean {
    const normalizedHost = hostname.toLowerCase();
    const normalizedDomain = domain.toLowerCase();
    return normalizedHost === normalizedDomain || normalizedHost.endsWith(`.${normalizedDomain}`);
}

function matchDomains(domains: string[], sourceAppBundleIds: string[] = []): UrlMatcherFunction {
    return (url, { opener }) => {
        return matchesSourceApp(opener, sourceAppBundleIds) &&
            domains.some((domain) => hostMatchesDomain(url.hostname, domain));
    };
}

function urlContainsText(text: string): UrlMatcherFunction {
    const needle = text.toLowerCase();
    return (url) => `${url.host}${url.pathname}`.toLowerCase().includes(needle);
}

const ALL_URLS: UrlMatcherFunction = () => true;

const NON_LOCAL_HTTP_URL: UrlMatcherFunction = (url) => url.protocol === "http" && url.hostname !== "localhost";

const ENFORCE_HTTPS: UrlTransformer = (url) => {
    url.protocol = "https";
    return url;
};

function stripTrackingParams(url: URL): URL {
    const removeKeyPrefixes = ["utm_", "uta_"];
    const removeKeys = new Set(["fbclid", "gclid"]);

    for (const key of [...url.searchParams.keys()]) {
        if (removeKeys.has(key) || removeKeyPrefixes.some((prefix) => key.startsWith(prefix))) {
            url.searchParams.delete(key);
        }
    }

    return url;
}

function shellQuote(value: unknown): string {
    return `'${String(value).replace(/'/g, `'\\''`)}'`;
}

function pathBrowser(path: string, argsForUrl: (url: URL) => string[]): BrowserResolver {
    return (url) => ({
        name: path,
        appType: "path",
        args: argsForUrl(url),
    });
}

function shellBrowser(commandForUrl: (url: URL) => string): BrowserResolver {
    return pathBrowser("/bin/sh", (url) => ["-c", commandForUrl(url)]);
}
