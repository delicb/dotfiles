type ActiveBrowser = "firefox" | "helium";

type BrowserProfileSet = {
    personal: BrowserResolver;
    linear: BrowserResolver;
};

type FirefoxHostProfile = {
    aliases: string[];
    profiles: Record<BrowserKind, string>;
};

