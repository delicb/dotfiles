            linear: "/Users/del-boy/Library/Application Support/Firefox/Profiles/VyPT5Ram.Profile 1",
        },
    },
};

function normalizedHost(): string {
    return finicky.getSystemInfo().name
        .replace(/[\s\u00A0]+/g, "")
        .toLowerCase();
}

function firefoxProfile(kind: BrowserKind): string {
    const host = normalizedHost();
    for (const { aliases, profiles } of Object.values(FIREFOX_PROFILES_BY_HOST)) {
        if (aliases.some((alias) => host.includes(alias))) {
            return profiles[kind];
        }
    }
    return FIREFOX_PROFILES_BY_HOST.zaphod.profiles[kind];
}

function firefoxBrowser(kind: BrowserKind): BrowserResolver {
    return pathBrowser(FIREFOX_PATH, (url) => ["--profile", firefoxProfile(kind), url.href]);
}

function heliumBrowser(profileDirectory: string): BrowserResolver {
    return shellBrowser((url) => `${shellQuote(HELIUM_PATH)} --profile-directory=${shellQuote(profileDirectory)} ${shellQuote(url.href)}`);
}

const PERSONAL_FIREFOX: BrowserResolver = firefoxBrowser("personal");
const LINEAR_FIREFOX: BrowserResolver = firefoxBrowser("linear");
const PERSONAL_HELIUM: BrowserResolver = heliumBrowser("Default");
