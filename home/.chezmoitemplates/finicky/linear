const PRIVATE_FIREFOX = (url) => ({
    name: "/opt/homebrew/bin/firefox",
    appType: "path",
    args: ["--profile", "/Users/del-boy/Library/Application Support/Firefox/Profiles/2c0ncgn9.default-release/", `${url.href}`],
})

const LINEAR_FIREFOX = (url) => ({
    name: "/opt/homebrew/bin/firefox",
    appType: "path",
    args: ["--profile", "/Users/del-boy/Library/Application Support/Firefox/Profiles/Q2qCNG2I.Profile 1", `${url.href}`],
})

// domains that should always open in Linear Firefox profile
const LINEAR_DOMAINS = [
    "openai.com",
    "zoom.us",
    "console.cloud.google.com",
    "accounts.google.com",
    "amazonaws.com",
    "datadoghq.com",
    "notion.so",
    "ramp.com",
    "retool.com",
    "dash.cloudflare.com",
    "us.hevodata.com",
    "sentry.dev",
    "app.vacationtracker.io",
    "salesforce.com",
];

const SOCIAL_NETWORK_DOMAINS = [
    "facebook.com",
    "twitter.com",
    "instagram.com",
    "youtube.com",
    "linkedin.com",
    "hachyderm.io",
    "reddit.com"
];

const OPEN_LINEAR_IN_DESKTOP_APP = false;
const LINEAR_LOCALHOST_PORTS = new Set(["8787", "8080", "8788"]);

function linearDesktopUrl(url) {
    const search = url.search ? `?${url.search}` : '';
    if (url.host === "linear.review") {
        return `linear://linear.app/review${url.pathname}${search}`;
    }
    return `linear://${url.pathname.substring(1)}${search}`;
}

/**
 * @type {FinickyConfig}
 */
export default {
    defaultBrowser: PRIVATE_FIREFOX,

    options: {
        logRequests: false,
    },

    rewrite: [
        {
            match: (url) => url.protocol === "http" && url.hostname !== "localhost",
            url: (url) => {
                url.protocol = "https";
                return url;
            }
        },
        {
            match: () => true,
            url: stripTrackingParams,
        },
    ],

    handlers: [
        {
            match: () => finicky.getModifierKeys().shift,
            browser: PRIVATE_FIREFOX,
        },
        {
            match: () => finicky.getModifierKeys().option,
            browser: LINEAR_FIREFOX,
        },
        {
            match: (url) => url.hostname == "localhost" && LINEAR_LOCALHOST_PORTS.has(url.port),
            browser: LINEAR_FIREFOX,
        },
        // linear.app and linear.review -> Linear desktop app via linear:// scheme
        {
            match: (url) => OPEN_LINEAR_IN_DESKTOP_APP && (url.host === "linear.app" || url.host.endsWith(".linear.app") || url.host === "linear.review"),
            browser: (url) => ({
                name: "/bin/sh",
                appType: "path",
                args: ["-c", `open '${linearDesktopUrl(url)}'`],
            }),
        },

        // anything else with "linear" in the URL -> Linear Firefox profile
        {
            match: (url) => /linear/i.test(url.host + url.pathname),
            browser: LINEAR_FIREFOX,
        },

        {
            match: matchDomains(LINEAR_DOMAINS),
            browser: LINEAR_FIREFOX,
        },

        // social networks explicitly go to private Firefox profile
        {
            match: matchDomains(SOCIAL_NETWORK_DOMAINS),
            browser: PRIVATE_FIREFOX,
        },
    ]
}
