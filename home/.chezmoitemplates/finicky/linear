const ACTIVE_BROWSER: ActiveBrowser = "helium";
const BROWSER: BrowserProfileSet = BROWSER_PROFILES[ACTIVE_BROWSER];

function routeToPersonal(match: UrlMatcher | UrlMatcher[]): BrowserHandler {
    return { match, browser: BROWSER.personal };
}

function routeToLinear(match: UrlMatcher | UrlMatcher[]): BrowserHandler {
    return { match, browser: BROWSER.linear };
}

const LINEAR_DOMAINS: string[] = [
    "openai.com",
    "zoom.us",
    "console.cloud.google.com",
    "accounts.google.com",
    "amazonaws.com",
    "datadoghq.com",
    "notion.so",
    "ramp.com",
    "retool.com",
    "dash.cloudflare.com",
    "us.hevodata.com",
    "sentry.dev",
    "app.vacationtracker.io",
    "salesforce.com",
    "app.launchdarkly.com",
    "ngrok.io",
    "incident.io",
    "sanity.io",
    "awsapps.com",
    //"claude.ai",
];

const SOCIAL_NETWORK_DOMAINS: string[] = [
    "facebook.com",
    "twitter.com",
    "instagram.com",
    "youtube.com",
    "linkedin.com",
    "hachyderm.io",
    "reddit.com"
];

const OPEN_LINEAR_IN_DESKTOP_APP = true;
const LINEAR_OWNER = "linear";
const LINEAR_LOCALHOST_PORTS: Set<string> = new Set(["8787", "8080", "8788"]);

const SHIFT_HELD: UrlMatcherFunction = () => finicky.getModifierKeys().shift;
const OPTION_HELD: UrlMatcherFunction = () => finicky.getModifierKeys().option;
const LINEAR_LOCALHOST: UrlMatcherFunction = (url) => url.hostname === "localhost" && LINEAR_LOCALHOST_PORTS.has(url.port);

function hasLinearOwnerPath(url: URL): boolean {
    return url.pathname.startsWith(`/${LINEAR_OWNER}/`);
}

function isLinearDesktopWebUrl(url: URL): boolean {
    return url.protocol === "https:" &&
        (url.hostname === "linear.app" || url.hostname === "linear.review") &&
        hasLinearOwnerPath(url);
}

const SHOULD_OPEN_LINEAR_DESKTOP_APP: UrlMatcherFunction = (url) => OPEN_LINEAR_IN_DESKTOP_APP && isLinearDesktopWebUrl(url);

function linearDesktopUrl(url: URL): string {
    const search = url.search;
    if (url.hostname === "linear.review") {
        return `linear://linear.app/review${url.pathname}${search}`;
    }
    return `linear://${url.pathname.substring(1)}${search}`;
}

const LINEAR_DESKTOP_APP: BrowserResolver = shellBrowser((url) => `open ${shellQuote(linearDesktopUrl(url))}`);
const LINEAR_URL: UrlMatcherFunction = urlContainsText("linear");
const LINEAR_DOMAIN_URL: UrlMatcherFunction = matchDomains(LINEAR_DOMAINS);
const SOCIAL_NETWORK_URL: UrlMatcherFunction = matchDomains(SOCIAL_NETWORK_DOMAINS);

export default {
    defaultBrowser: BROWSER.personal,

    options: {
        logRequests: false,
    },

    rewrite: [
        {
            match: NON_LOCAL_HTTP_URL,
            url: ENFORCE_HTTPS,
        },
        {
            match: ALL_URLS,
            url: stripTrackingParams,
        },
    ],

    handlers: [
        routeToPersonal(SHIFT_HELD),
        routeToLinear(OPTION_HELD),
        routeToLinear(LINEAR_LOCALHOST),
        {
            match: SHOULD_OPEN_LINEAR_DESKTOP_APP,
            browser: LINEAR_DESKTOP_APP,
        },
        routeToLinear(LINEAR_URL),
        routeToLinear(LINEAR_DOMAIN_URL),
        routeToPersonal(SOCIAL_NETWORK_URL),
    ]
} satisfies FinickyConfig;
